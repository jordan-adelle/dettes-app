# Copie ce fichier en .env.local et remplis tes valeurs Supabase
# Supabase > Project Settings > API
# Avec Vite, le prefixe `VITE_` est le plus standard.
# Le projet accepte aussi `NEXT_PUBLIC_*` et `SUPABASE_*` sur Vercel.

VITE_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
